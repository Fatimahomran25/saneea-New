# Copy this file to backend/.env and replace placeholders with local secrets.

# Option 1: point to a local Firebase Admin service account JSON file.
# Relative paths are resolved from the backend/ directory.
FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccountKey.json

# Option 2: provide the full Firebase Admin JSON as a single environment value.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"replace_me"}

# Moyasar server-side secret key used by payment verification endpoints.
MOYASAR_SECRET_KEY=sk_test_replace_me
